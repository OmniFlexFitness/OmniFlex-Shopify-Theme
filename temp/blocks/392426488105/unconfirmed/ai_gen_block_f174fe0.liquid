{% doc %}
  @prompt
    Create an interactive rotating product display that spins when the user scrolls down on the page, Enable this custom component to be able to upload 3D models (.fbx) that can be rotated upon scroll, and allow users to control the staging and lighting of this product. Also make the layout of this custom section more similar to the other featured product layout
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-3d-product-display-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    background-color: {{ block.settings.background_color }};
  }

  .ai-3d-product-container-{{ ai_gen_id }} {
    max-width: 1200px;
    margin: 0 auto;
    padding: {{ block.settings.section_padding }}px 20px;
  }

  .ai-3d-product-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px;
    align-items: center;
  }

  .ai-3d-product-media-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
  }

  .ai-3d-product-viewer-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    height: {{ block.settings.viewer_height }}px;
    background-color: {{ block.settings.viewer_background }};
    border-radius: {{ block.settings.media_border_radius }}px;
    overflow: hidden;
  }

  .ai-3d-product-viewer-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
  }

  .ai-3d-product-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    border-radius: {{ block.settings.media_border_radius }}px;
    position: relative;
  }

  .ai-3d-product-placeholder-{{ ai_gen_id }} svg {
    width: 50%;
    height: 50%;
    max-width: 300px;
    max-height: 300px;
    opacity: 0.3;
  }

  .ai-3d-product-empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 30px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 24px;
    font-size: 14px;
    color: #666;
    text-align: center;
    background: rgba(255, 255, 255, 0.9);
    border-radius: 4px;
    max-width: 80%;
  }

  .ai-3d-product-controls-{{ ai_gen_id }} {
    margin-top: 20px;
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
  }

  .ai-3d-product-control-btn-{{ ai_gen_id }} {
    padding: 8px 16px;
    background-color: {{ block.settings.control_button_color }};
    color: {{ block.settings.control_button_text_color }};
    border: none;
    border-radius: 4px;
    cursor: pointer;
    font-size: 14px;
    transition: opacity 0.3s ease;
  }

  .ai-3d-product-control-btn-{{ ai_gen_id }}:hover {
    opacity: 0.8;
  }

  .ai-3d-product-control-btn-{{ ai_gen_id }}.active {
    background-color: {{ block.settings.text_color }};
    color: {{ block.settings.background_color }};
  }

  .ai-3d-product-info-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .ai-3d-product-heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.text_color }};
    margin: 0;
    line-height: 1.2;
  }

  .ai-3d-product-description-{{ ai_gen_id }} {
    font-size: {{ block.settings.description_size }}px;
    color: {{ block.settings.text_color }};
    opacity: 0.8;
    line-height: 1.6;
    margin: 0;
  }

  .ai-3d-product-price-{{ ai_gen_id }} {
    font-size: {{ block.settings.price_size }}px;
    color: {{ block.settings.text_color }};
    font-weight: 600;
    margin: 0;
  }

  .ai-3d-product-features-{{ ai_gen_id }} {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .ai-3d-product-feature-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 14px;
    color: {{ block.settings.text_color }};
  }

  .ai-3d-product-feature-icon-{{ ai_gen_id }} {
    width: 20px;
    height: 20px;
    flex-shrink: 0;
    color: {{ block.settings.button_color }};
  }

  .ai-3d-product-actions-{{ ai_gen_id }} {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
  }

  .ai-3d-product-button-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 14px 32px;
    background-color: {{ block.settings.button_color }};
    color: {{ block.settings.button_text_color }};
    text-decoration: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: 16px;
    font-weight: 500;
    transition: background-color 0.3s ease;
    border: none;
    cursor: pointer;
  }

  .ai-3d-product-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_color }};
  }

  .ai-3d-product-button-secondary-{{ ai_gen_id }} {
    background-color: transparent;
    color: {{ block.settings.text_color }};
    border: 1px solid {{ block.settings.text_color }};
  }

  .ai-3d-product-button-secondary-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.text_color }};
    color: {{ block.settings.background_color }};
  }

  .ai-3d-product-scroll-hint-{{ ai_gen_id }} {
    text-align: center;
    margin-top: 15px;
    font-size: 13px;
    color: {{ block.settings.text_color }};
    opacity: 0.6;
  }

  @media screen and (max-width: 989px) {
    .ai-3d-product-grid-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: 40px;
    }

    .ai-3d-product-viewer-wrapper-{{ ai_gen_id }} {
      height: 400px;
    }

    .ai-3d-product-heading-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.heading_size }}px * 0.8);
    }
  }

  @media screen and (max-width: 749px) {
    .ai-3d-product-viewer-wrapper-{{ ai_gen_id }} {
      height: 350px;
    }

    .ai-3d-product-actions-{{ ai_gen_id }} {
      flex-direction: column;
    }

    .ai-3d-product-button-{{ ai_gen_id }} {
      width: 100%;
    }
  }
{% endstyle %}

<product-3d-display-{{ ai_gen_id }}
  class="ai-3d-product-display-{{ ai_gen_id }}"
  data-scroll-rotation="{{ block.settings.enable_scroll_rotation }}"
  data-rotation-speed="{{ block.settings.rotation_speed }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-3d-product-container-{{ ai_gen_id }}">
    <div class="ai-3d-product-grid-{{ ai_gen_id }}">
      <div class="ai-3d-product-media-{{ ai_gen_id }}">
        <div class="ai-3d-product-viewer-wrapper-{{ ai_gen_id }}">
          {% if block.settings.product != blank %}
            {% assign has_3d_model = false %}
            {% for media in block.settings.product.media %}
              {% if media.media_type == 'model' %}
                {% assign has_3d_model = true %}
                <model-viewer
                  class="ai-3d-product-viewer-{{ ai_gen_id }}"
                  src="{{ media.sources[1].url }}"
                  alt="{{ media.alt | escape }}"
                  camera-controls
                  {% if block.settings.auto_rotate %}auto-rotate{% endif %}
                  {% if block.settings.enable_ar %}ar{% endif %}
                  shadow-intensity="{{ block.settings.shadow_intensity }}"
                  exposure="{{ block.settings.exposure }}"
                  environment-image="{{ block.settings.environment }}"
                  data-model-id="{{ media.id }}"
                >
                </model-viewer>
                {% break %}
              {% endif %}
            {% endfor %}

            {% unless has_3d_model %}
              <div class="ai-3d-product-placeholder-{{ ai_gen_id }}">
                {{ 'product-1' | placeholder_svg_tag }}
                <div class="ai-3d-product-empty-state-{{ ai_gen_id }}">
                  Upload a 3D model (.glb) to the product media to enable 3D viewing
                </div>
              </div>
            {% endunless %}
          {% else %}
            <div class="ai-3d-product-placeholder-{{ ai_gen_id }}">
              {{ 'product-1' | placeholder_svg_tag }}
              <div class="ai-3d-product-empty-state-{{ ai_gen_id }}">
                Next, select a product with a 3D model
              </div>
            </div>
          {% endif %}
        </div>

        {% if block.settings.show_controls %}
          <div class="ai-3d-product-controls-{{ ai_gen_id }}">
            <button class="ai-3d-product-control-btn-{{ ai_gen_id }}" data-action="reset-camera">
              Reset view
            </button>
            {% if block.settings.enable_ar %}
              <button class="ai-3d-product-control-btn-{{ ai_gen_id }}" data-action="view-ar">
                View in AR
              </button>
            {% endif %}
          </div>
        {% endif %}

        {% if block.settings.show_scroll_hint %}
          <div class="ai-3d-product-scroll-hint-{{ ai_gen_id }}">
            Scroll to rotate • Drag to explore
          </div>
        {% endif %}
      </div>

      <div class="ai-3d-product-info-{{ ai_gen_id }}">
        {% if block.settings.product != blank %}
          <h2 class="ai-3d-product-heading-{{ ai_gen_id }}">{{ block.settings.product.title }}</h2>

          {% if block.settings.product.description != blank %}
            <div class="ai-3d-product-description-{{ ai_gen_id }}">
              {{ block.settings.product.description | strip_html | truncate: 200 }}
            </div>
          {% endif %}

          <div class="ai-3d-product-price-{{ ai_gen_id }}">
            {{ block.settings.product.price | money }}
          </div>

          {% if block.settings.show_features %}
            <ul class="ai-3d-product-features-{{ ai_gen_id }}">
              {% if block.settings.feature_1 != blank %}
                <li class="ai-3d-product-feature-{{ ai_gen_id }}">
                  <svg class="ai-3d-product-feature-icon-{{ ai_gen_id }}" viewBox="0 0 20 20" fill="currentColor">
                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                  </svg>
                  <span>{{ block.settings.feature_1 }}</span>
                </li>
              {% endif %}
              {% if block.settings.feature_2 != blank %}
                <li class="ai-3d-product-feature-{{ ai_gen_id }}">
                  <svg class="ai-3d-product-feature-icon-{{ ai_gen_id }}" viewBox="0 0 20 20" fill="currentColor">
                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                  </svg>
                  <span>{{ block.settings.feature_2 }}</span>
                </li>
              {% endif %}
              {% if block.settings.feature_3 != blank %}
                <li class="ai-3d-product-feature-{{ ai_gen_id }}">
                  <svg class="ai-3d-product-feature-icon-{{ ai_gen_id }}" viewBox="0 0 20 20" fill="currentColor">
                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                  </svg>
                  <span>{{ block.settings.feature_3 }}</span>
                </li>
              {% endif %}
            </ul>
          {% endif %}

          <div class="ai-3d-product-actions-{{ ai_gen_id }}">
            <a href="{{ block.settings.product.url }}" class="ai-3d-product-button-{{ ai_gen_id }}">
              {{ block.settings.button_text }}
            </a>
            {% if block.settings.show_secondary_button %}
              <a href="{{ block.settings.secondary_button_link }}" class="ai-3d-product-button-{{ ai_gen_id }} ai-3d-product-button-secondary-{{ ai_gen_id }}">
                {{ block.settings.secondary_button_text }}
              </a>
            {% endif %}
          </div>
        {% else %}
          <h2 class="ai-3d-product-heading-{{ ai_gen_id }}">{{ block.settings.fallback_heading }}</h2>
          <div class="ai-3d-product-description-{{ ai_gen_id }}">
            {{ block.settings.fallback_description }}
          </div>
        {% endif %}
      </div>
    </div>
  </div>
</product-3d-display-{{ ai_gen_id }}>

<script type="module">
  import 'https://ajax.googleapis.com/ajax/libs/model-viewer/3.3.0/model-viewer.min.js';
</script>

<script>
  (function() {
    class Product3DDisplay{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.modelViewer = null;
        this.lastScrollY = 0;
        this.currentRotation = 0;
        this.scrollRotationEnabled = false;
        this.rotationSpeed = 0.5;
        this.ticking = false;
      }

      connectedCallback() {
        this.scrollRotationEnabled = this.dataset.scrollRotation === 'true';
        this.rotationSpeed = parseFloat(this.dataset.rotationSpeed) || 0.5;

        setTimeout(() => {
          this.modelViewer = this.querySelector('model-viewer');
          
          if (this.modelViewer) {
            this.setupModelViewer();
            this.setupControls();
            
            if (this.scrollRotationEnabled) {
              this.setupScrollRotation();
            }
          }
        }, 100);
      }

      setupModelViewer() {
        this.modelViewer.addEventListener('load', () => {
          this.modelViewer.style.opacity = '1';
        });

        this.modelViewer.addEventListener('error', (event) => {
          console.error('Model loading error:', event);
        });
      }

      setupControls() {
        const controls = this.querySelectorAll('.ai-3d-product-control-btn-{{ ai_gen_id }}');
        
        controls.forEach(button => {
          button.addEventListener('click', (e) => {
            const action = e.target.dataset.action;
            
            if (action === 'reset-camera' && this.modelViewer) {
              this.modelViewer.resetTurntableRotation();
              this.modelViewer.cameraOrbit = 'auto auto auto';
              this.currentRotation = 0;
            } else if (action === 'view-ar' && this.modelViewer) {
              this.modelViewer.activateAR();
            }
          });
        });
      }

      setupScrollRotation() {
        this.lastScrollY = window.scrollY;
        
        window.addEventListener('scroll', () => {
          if (!this.ticking) {
            window.requestAnimationFrame(() => {
              this.handleScroll();
              this.ticking = false;
            });
            this.ticking = true;
          }
        });
      }

      handleScroll() {
        if (!this.modelViewer) return;

        const currentScrollY = window.scrollY;
        const scrollDelta = currentScrollY - this.lastScrollY;
        this.lastScrollY = currentScrollY;

        this.currentRotation += scrollDelta * this.rotationSpeed;

        const currentOrbit = this.modelViewer.getCameraOrbit();
        this.modelViewer.cameraOrbit = `${this.currentRotation}deg ${currentOrbit.theta}rad ${currentOrbit.radius}m`;
      }

      disconnectedCallback() {
        if (this.scrollRotationEnabled) {
          window.removeEventListener('scroll', this.handleScroll);
        }
      }
    }

    customElements.define('product-3d-display-{{ ai_gen_id }}', Product3DDisplay{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "3D product display",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Product"
    },
    {
      "type": "product",
      "id": "product",
      "label": "Product",
      "info": "Select a product with a 3D model (.glb file) in its media"
    },
    {
      "type": "text",
      "id": "fallback_heading",
      "label": "Fallback heading",
      "default": "Experience in 3D"
    },
    {
      "type": "textarea",
      "id": "fallback_description",
      "label": "Fallback description",
      "default": "View our products in stunning 3D detail"
    },
    {
      "type": "header",
      "content": "3D viewer settings"
    },
    {
      "type": "checkbox",
      "id": "enable_scroll_rotation",
      "label": "Enable scroll rotation",
      "default": true,
      "info": "Rotate the model as you scroll"
    },
    {
      "type": "range",
      "id": "rotation_speed",
      "label": "Scroll rotation speed",
      "min": 0,
      "max": 2,
      "step": 0.5,
      "default": 0.5
    },
    {
      "type": "checkbox",
      "id": "auto_rotate",
      "label": "Auto-rotate",
      "default": false,
      "info": "Automatically rotate the model"
    },
    {
      "type": "checkbox",
      "id": "enable_ar",
      "label": "Enable AR viewing",
      "default": true,
      "info": "Allow viewing in augmented reality on compatible devices"
    },
    {
      "type": "checkbox",
      "id": "show_controls",
      "label": "Show control buttons",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_scroll_hint",
      "label": "Show scroll hint",
      "default": true
    },
    {
      "type": "range",
      "id": "viewer_height",
      "label": "Viewer height",
      "min": 300,
      "max": 700,
      "step": 50,
      "unit": "px",
      "default": 500
    },
    {
      "type": "header",
      "content": "Lighting and environment"
    },
    {
      "type": "select",
      "id": "environment",
      "label": "Environment",
      "options": [
        {
          "value": "neutral",
          "label": "Neutral"
        },
        {
          "value": "legacy",
          "label": "Legacy"
        },
        {
          "value": "studio",
          "label": "Studio"
        }
      ],
      "default": "neutral",
      "info": "Background lighting environment"
    },
    {
      "type": "range",
      "id": "exposure",
      "label": "Exposure",
      "min": 0,
      "max": 2,
      "step": 0.5,
      "default": 1,
      "info": "Overall brightness"
    },
    {
      "type": "range",
      "id": "shadow_intensity",
      "label": "Shadow intensity",
      "min": 0,
      "max": 2,
      "step": 0.5,
      "default": 1
    },
    {
      "type": "color",
      "id": "viewer_background",
      "label": "Viewer background",
      "default": "#f4f4f4"
    },
    {
      "type": "header",
      "content": "Product features"
    },
    {
      "type": "checkbox",
      "id": "show_features",
      "label": "Show features",
      "default": true
    },
    {
      "type": "text",
      "id": "feature_1",
      "label": "Feature 1",
      "default": "Premium quality materials"
    },
    {
      "type": "text",
      "id": "feature_2",
      "label": "Feature 2",
      "default": "Expertly crafted design"
    },
    {
      "type": "text",
      "id": "feature_3",
