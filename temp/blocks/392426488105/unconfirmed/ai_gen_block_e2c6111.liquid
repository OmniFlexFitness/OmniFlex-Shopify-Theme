{% doc %}
  @prompt
    Create an interactive rotating product display that spins when the user scrolls down on the page
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-scroll-rotate-display-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.section_padding }}px 0;
    background-color: {{ block.settings.background_color }};
  }

  .ai-scroll-rotate-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .ai-scroll-rotate-content-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 30px;
  }

  .ai-scroll-rotate-text-{{ ai_gen_id }} {
    text-align: center;
    max-width: 600px;
  }

  .ai-scroll-rotate-heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.text_color }};
    margin: 0 0 15px;
  }

  .ai-scroll-rotate-subheading-{{ ai_gen_id }} {
    font-size: {{ block.settings.subheading_size }}px;
    color: {{ block.settings.text_color }};
    opacity: 0.8;
    margin: 0;
  }

  .ai-scroll-rotate-product-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    max-width: {{ block.settings.product_size }}px;
    height: {{ block.settings.product_size }}px;
    perspective: 1000px;
  }

  .ai-scroll-rotate-product-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    position: relative;
    transform-style: preserve-3d;
    transition: transform 0.1s ease-out;
  }

  .ai-scroll-rotate-image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: contain;
    border-radius: {{ block.settings.image_border_radius }}px;
  }

  .ai-scroll-rotate-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: {{ block.settings.image_border_radius }}px;
    position: relative;
  }

  .ai-scroll-rotate-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-scroll-rotate-empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  .ai-scroll-rotate-product-info-{{ ai_gen_id }} {
    text-align: center;
    margin-top: 20px;
  }

  .ai-scroll-rotate-product-title-{{ ai_gen_id }} {
    font-size: 24px;
    color: {{ block.settings.text_color }};
    margin: 0 0 10px;
  }

  .ai-scroll-rotate-product-price-{{ ai_gen_id }} {
    font-size: 20px;
    color: {{ block.settings.text_color }};
    margin: 0 0 20px;
  }

  .ai-scroll-rotate-product-link-{{ ai_gen_id }} {
    display: inline-block;
    padding: 12px 30px;
    background-color: {{ block.settings.button_color }};
    color: {{ block.settings.button_text_color }};
    text-decoration: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    transition: background-color 0.3s ease;
  }

  .ai-scroll-rotate-product-link-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_color }};
  }

  .ai-scroll-rotate-scroll-indicator-{{ ai_gen_id }} {
    text-align: center;
    margin-top: 30px;
    font-size: 14px;
    color: {{ block.settings.text_color }};
    opacity: 0.6;
  }

  @media screen and (max-width: 749px) {
    .ai-scroll-rotate-product-wrapper-{{ ai_gen_id }} {
      max-width: 300px;
      height: 300px;
    }

    .ai-scroll-rotate-heading-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.heading_size }}px * 0.8);
    }

    .ai-scroll-rotate-subheading-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.subheading_size }}px * 0.9);
    }
  }
{% endstyle %}

<scroll-rotate-display-{{ ai_gen_id }}
  class="ai-scroll-rotate-display-{{ ai_gen_id }}"
  data-rotation-speed="{{ block.settings.rotation_speed }}"
  data-rotation-axis="{{ block.settings.rotation_axis }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-scroll-rotate-container-{{ ai_gen_id }}">
    <div class="ai-scroll-rotate-content-{{ ai_gen_id }}">
      {% if block.settings.heading != blank or block.settings.subheading != blank %}
        <div class="ai-scroll-rotate-text-{{ ai_gen_id }}">
          {% if block.settings.heading != blank %}
            <h2 class="ai-scroll-rotate-heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
          {% endif %}
          {% if block.settings.subheading != blank %}
            <p class="ai-scroll-rotate-subheading-{{ ai_gen_id }}">{{ block.settings.subheading }}</p>
          {% endif %}
        </div>
      {% endif %}

      <div class="ai-scroll-rotate-product-wrapper-{{ ai_gen_id }}">
        <div class="ai-scroll-rotate-product-{{ ai_gen_id }}">
          {% if block.settings.product != blank %}
            {% if block.settings.product.featured_image %}
              <img
                src="{{ block.settings.product.featured_image | image_url: width: 800 }}"
                alt="{{ block.settings.product.featured_image.alt | escape }}"
                class="ai-scroll-rotate-image-{{ ai_gen_id }}"
                loading="lazy"
                width="800"
                height="800"
              >
            {% else %}
              <div class="ai-scroll-rotate-placeholder-{{ ai_gen_id }}">
                {{ 'product-1' | placeholder_svg_tag }}
              </div>
            {% endif %}
          {% else %}
            <div class="ai-scroll-rotate-placeholder-{{ ai_gen_id }}">
              {{ 'product-1' | placeholder_svg_tag }}
              <div class="ai-scroll-rotate-empty-state-{{ ai_gen_id }}">
                Next, select a product to display
              </div>
            </div>
          {% endif %}
        </div>
      </div>

      {% if block.settings.product != blank %}
        <div class="ai-scroll-rotate-product-info-{{ ai_gen_id }}">
          <h3 class="ai-scroll-rotate-product-title-{{ ai_gen_id }}">{{ block.settings.product.title }}</h3>
          <div class="ai-scroll-rotate-product-price-{{ ai_gen_id }}">{{ block.settings.product.price | money }}</div>
          <a href="{{ block.settings.product.url }}" class="ai-scroll-rotate-product-link-{{ ai_gen_id }}">
            {{ block.settings.button_text }}
          </a>
        </div>
      {% endif %}

      {% if block.settings.show_scroll_indicator %}
        <div class="ai-scroll-rotate-scroll-indicator-{{ ai_gen_id }}">
          Scroll to rotate
        </div>
      {% endif %}
    </div>
  </div>
</scroll-rotate-display-{{ ai_gen_id }}>

<script>
  (function() {
    class ScrollRotateDisplay{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.productElement = null;
        this.lastScrollY = 0;
        this.currentRotation = { x: 0, y: 0 };
        this.rotationSpeed = 1;
        this.rotationAxis = 'y';
        this.ticking = false;
      }

      connectedCallback() {
        this.productElement = this.querySelector('.ai-scroll-rotate-product-{{ ai_gen_id }}');
        this.rotationSpeed = parseFloat(this.dataset.rotationSpeed) || 1;
        this.rotationAxis = this.dataset.rotationAxis || 'y';
        
        if (this.productElement) {
          this.setupScrollListener();
        }
      }

      setupScrollListener() {
        this.lastScrollY = window.scrollY;
        
        window.addEventListener('scroll', () => {
          if (!this.ticking) {
            window.requestAnimationFrame(() => {
              this.handleScroll();
              this.ticking = false;
            });
            this.ticking = true;
          }
        });
      }

      handleScroll() {
        const currentScrollY = window.scrollY;
        const scrollDelta = currentScrollY - this.lastScrollY;
        this.lastScrollY = currentScrollY;

        const rotationAmount = scrollDelta * this.rotationSpeed;

        if (this.rotationAxis === 'y') {
          this.currentRotation.y += rotationAmount;
        } else if (this.rotationAxis === 'x') {
          this.currentRotation.x += rotationAmount;
        } else if (this.rotationAxis === 'both') {
          this.currentRotation.y += rotationAmount;
          this.currentRotation.x += rotationAmount * 0.5;
        }

        this.updateRotation();
      }

      updateRotation() {
        if (this.productElement) {
          this.productElement.style.transform = `rotateX(${this.currentRotation.x}deg) rotateY(${this.currentRotation.y}deg)`;
        }
      }

      disconnectedCallback() {
        window.removeEventListener('scroll', this.handleScroll);
      }
    }

    customElements.define('scroll-rotate-display-{{ ai_gen_id }}', ScrollRotateDisplay{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Scroll rotating product",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Product"
    },
    {
      "type": "product",
      "id": "product",
      "label": "Product"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "View product"
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Explore in 3D"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Scroll down to rotate and view from every angle"
    },
    {
      "type": "checkbox",
      "id": "show_scroll_indicator",
      "label": "Show scroll indicator",
      "default": true
    },
    {
      "type": "header",
      "content": "Rotation settings"
    },
    {
      "type": "select",
      "id": "rotation_axis",
      "label": "Rotation axis",
      "options": [
        {
          "value": "y",
          "label": "Horizontal (Y-axis)"
        },
        {
          "value": "x",
          "label": "Vertical (X-axis)"
        },
        {
          "value": "both",
          "label": "Both axes"
        }
      ],
      "default": "y"
    },
    {
      "type": "range",
      "id": "rotation_speed",
      "label": "Rotation speed",
      "min": 0.5,
      "max": 3,
      "step": 0.5,
      "default": 1
    },
    {
      "type": "range",
      "id": "product_size",
      "label": "Product size",
      "min": 200,
      "max": 600,
      "step": 50,
      "unit": "px",
      "default": 400
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "range",
      "id": "max_width",
      "label": "Maximum content width",
      "min": 600,
      "max": 1400,
      "step": 100,
      "unit": "px",
      "default": 1000
    },
    {
      "type": "range",
      "id": "section_padding",
      "label": "Section padding",
      "min": 0,
      "max": 100,
      "step": 10,
      "unit": "px",
      "default": 60
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#121212"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Heading size",
      "min": 20,
      "max": 60,
      "step": 2,
      "unit": "px",
      "default": 36
    },
    {
      "type": "range",
      "id": "subheading_size",
      "label": "Subheading size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "image_border_radius",
      "label": "Image border radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 0
    },
    {
      "type": "header",
      "content": "Button"
    },
    {
      "type": "color",
      "id": "button_color",
      "label": "Button color",
      "default": "#121212"
    },
    {
      "type": "color",
      "id": "button_hover_color",
      "label": "Button hover color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Button text color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "button_border_radius",
      "label": "Button border radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "Scroll rotating product"
    }
  ]
}
{% endschema %}