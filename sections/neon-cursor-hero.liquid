{{ 'section-neon-cursor-hero.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign now_year = 'now' | date: '%Y'
  assign drop_id = section.settings.drop_id | default: 'DROP-003'
  assign heading_font = section.settings.heading_font
  assign body_font = section.settings.body_font

  assign pillars = section.blocks | where: 'type', 'pillar'
  assign stats = section.blocks | where: 'type', 'stat'
  assign drop_blocks = section.blocks | where: 'type', 'drop_card'
  assign drop_card = drop_blocks | first
-%}

{%- style -%}
  {{ heading_font | font_face: font_display: 'swap' }}
  {{ body_font | font_face: font_display: 'swap' }}

  #shopify-section-{{ section.id }} { margin: 0; padding: 0; }
  .neon-hero--{{ section.id }} {
    min-height: {{ section.settings.section_height }}svh;
    --heading-font: {{ heading_font.family }}, {{ heading_font.fallback_families }};
    --heading-color: {{ section.settings.heading_color }};
    --heading-stroke: 1.5px;
    --body-font: {{ body_font.family }}, {{ body_font.fallback_families }};
    --body-color: {{ section.settings.body_color }};
    --accent-font: {{ body_font.family }}, {{ body_font.fallback_families }};
    --accent-color: {{ section.settings.body_color }};
    --stat-value-font: {{ heading_font.family }}, {{ heading_font.fallback_families }};
    --stat-value-color: {{ section.settings.heading_color }};
    --pillar-label-color: {{ section.settings.heading_color }};
  }
{%- endstyle -%}

<neon-cursor-hero
  class="neon-hero neon-hero--{{ section.id }}"
  data-headline-style="{{ section.settings.heading_style }}"
  data-stat-style="{{ section.settings.heading_style }}"
  data-hide-native-cursor="{{ section.settings.enable_cursor_light }}"
>
  <canvas class="neon-hero__canvas" aria-hidden="true"></canvas>
  <div class="neon-hero__grid" aria-hidden="true"></div>
  <div class="neon-hero__scanline" aria-hidden="true"></div>

  {%- if section.settings.enable_cursor_light -%}
    <div class="neon-hero__cursor" data-active="false" aria-hidden="true">
      <span class="neon-hero__cursor-ring"></span>
      <span class="neon-hero__cursor-corner neon-hero__cursor-corner--tl"></span>
      <span class="neon-hero__cursor-corner neon-hero__cursor-corner--tr"></span>
      <span class="neon-hero__cursor-corner neon-hero__cursor-corner--bl"></span>
      <span class="neon-hero__cursor-corner neon-hero__cursor-corner--br"></span>
    </div>
  {%- endif -%}

  <div class="neon-hero__frame" aria-hidden="true">
    <span></span><span></span>
  </div>

  <div class="neon-hero__monogram" aria-label="OmniFlex">
    <svg class="neon-hero__mark" viewBox="0 0 32 32" fill="none" aria-hidden="true">
      <defs>
        <linearGradient id="ofx-mark-{{ section.id }}" x1="0" y1="0" x2="32" y2="32" gradientUnits="userSpaceOnUse">
          <stop offset="0" stop-color="#0aeaed"/>
          <stop offset="1" stop-color="#fa0dfd"/>
        </linearGradient>
      </defs>
      <path d="M4 16 L16 4 L28 16 L16 28 Z" stroke="url(#ofx-mark-{{ section.id }})" stroke-width="2" fill="none"/>
      <path d="M10 16 L16 10 L22 16 L16 22 Z" fill="url(#ofx-mark-{{ section.id }})"/>
    </svg>
    <span>OmniFlex</span>
  </div>

  <div class="neon-hero__readout" aria-hidden="true">
    <span>SYS</span><span>OMNIFLEX_<em>OS</em></span>
    <span>SEQ</span><span>{{ drop_id }}</span>
    <span>YR</span><span>{{ now_year }}</span>
    <span>STATE</span><span><em>LIVE</em></span>
  </div>

  {%- if section.settings.rail_text != blank -%}
    <div class="neon-hero__rail" aria-hidden="true">
      <span>{{ section.settings.rail_text | escape }}</span>
      <span class="neon-hero__rail-dot"></span>
      <span>Wear · Fuel · Train</span>
    </div>
  {%- endif -%}

  <div class="neon-hero__content">
    {%- if section.settings.eyebrow != blank -%}
      <span class="neon-hero__eyebrow">{{ section.settings.eyebrow | escape }}</span>
    {%- endif -%}

    {%- if section.settings.heading != blank -%}
      <h1 class="neon-hero__headline">
        {%- assign lines = section.settings.heading | newline_to_br | split: '<br />' -%}
        {%- for line in lines -%}
          {%- assign trimmed = line | strip -%}
          {%- if trimmed != blank -%}
            <span class="neon-hero__headline-line">{{ trimmed }}</span>
          {%- endif -%}
        {%- endfor -%}
      </h1>
    {%- endif -%}

    {%- if section.settings.subheading != blank -%}
      <p class="neon-hero__subheading">{{ section.settings.subheading | escape }}</p>
    {%- endif -%}

    <div class="neon-hero__cta-row">
      {%- if section.settings.primary_label != blank -%}
        <a class="neon-hero__cta" href="{{ section.settings.primary_link | default: '#' }}">
          {{ section.settings.primary_label | escape }}
          <span aria-hidden="true">&rarr;</span>
        </a>
      {%- endif -%}
      {%- if section.settings.secondary_label != blank -%}
        <a class="neon-hero__cta neon-hero__cta--ghost" href="{{ section.settings.secondary_link | default: '#' }}">
          {{ section.settings.secondary_label | escape }}
        </a>
      {%- endif -%}
    </div>

    {%- if pillars.size > 0 -%}
      <div class="neon-hero__pillars">
        {%- for block in pillars -%}
          <div class="neon-hero__pillar" {{ block.shopify_attributes }}>
            {%- case block.settings.icon -%}
            {%- when 'wear' -%}
              <svg class="neon-hero__pillar-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path d="M5 4l4 1 3-2 3 2 4-1v6l-4 1-3 2-3-2-4-1z"/><path d="M9 11v9M15 11v9"/></svg>
            {%- when 'fuel' -%}
              <svg class="neon-hero__pillar-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><rect x="7" y="3" width="10" height="4" rx="1"/><path d="M8 7h8l-1 13a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/><path d="M9 12h6"/></svg>
            {%- when 'train' -%}
              <svg class="neon-hero__pillar-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path d="M3 12h2l3-7 4 14 3-9 2 4h4"/></svg>
            {%- else -%}
              <svg class="neon-hero__pillar-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path d="M12 2l9 5v10l-9 5-9-5V7z"/></svg>
            {%- endcase -%}
            <span class="neon-hero__pillar-label">{{ block.settings.label | escape }}</span>
            {%- if block.settings.sublabel != blank -%}
              <span class="neon-hero__pillar-sub">{{ block.settings.sublabel | escape }}</span>
            {%- endif -%}
          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>

  {%- if drop_card -%}
    <a class="neon-hero__drop-card" href="{{ drop_card.settings.link | default: '#' }}" {{ drop_card.shopify_attributes }}>
      <span class="neon-hero__drop-tag">
        <span style="display:inline-block;width:6px;height:6px;background:#07041f;border-radius:50%;"></span>
        {{ drop_card.settings.tag | escape }}
      </span>
      <h3 class="neon-hero__drop-title">{{ drop_card.settings.title | escape }}</h3>
      <div class="neon-hero__drop-meta">
        <span>{{ drop_card.settings.meta | escape }}</span>
      </div>
      <span class="neon-hero__drop-cta">
        {{ drop_card.settings.cta_label | default: 'View drop' | escape }} <span aria-hidden="true">&rarr;</span>
      </span>
    </a>
  {%- endif -%}

  {%- if stats.size > 0 -%}
    <div class="neon-hero__stats" aria-label="Brand metrics">
      {%- for block in stats -%}
        <div class="neon-hero__stat" {{ block.shopify_attributes }}>
          <strong>{{ block.settings.value | escape }}</strong>
          {{ block.settings.label | escape }}
        </div>
        {%- unless forloop.last -%}
          <div class="neon-hero__stat-divider" aria-hidden="true"></div>
        {%- endunless -%}
      {%- endfor -%}
    </div>
  {%- endif -%}

  {%- if section.settings.scroll_hint != blank -%}
    <div class="neon-hero__hint">{{ section.settings.scroll_hint | escape }} &darr;</div>
  {%- endif -%}

  <script type="application/json" class="neon-hero__data">
    {
      "colorA": {{ section.settings.color_a | json }},
      "colorB": {{ section.settings.color_b | json }},
      "bloomStrength": 1.4,
      "tubeCount": {{ section.settings.tube_count }},
      "trailLength": 80,
      "starCount": {{ section.settings.star_count }},
      "showGrid": true,
      "cursorLight": {
        "enabled": {{ section.settings.enable_cursor_light | json }},
        "outerColor": {{ section.settings.cursor_light_outer_color | json }},
        "innerColor": {{ section.settings.cursor_light_inner_color | json }},
        "radius": {{ section.settings.cursor_light_radius }},
        "intensity": {{ section.settings.cursor_light_intensity }},
        "pulseSpeed": 4,
        "ringWidth": 0.07
      }
    }
  </script>

  <script type="importmap">
    {
      "imports": {
        "three": "https://cdn.jsdelivr.net/npm/three@0.162.0/build/three.module.js",
        "three/addons/": "https://cdn.jsdelivr.net/npm/three@0.162.0/examples/jsm/"
      }
    }
  </script>
  <script type="module" src="{{ 'neon-cursor-hero.js' | asset_url }}"></script>
</neon-cursor-hero>

{% schema %}
{
  "name": "OmniFlex 3D — Neon Cursor Hero",
  "tag": "section",
  "class": "section section--neon-hero section--omniflex-3d",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "OmniFlex // 2026 // System Live"
    },
    {
      "type": "textarea",
      "id": "heading",
      "label": "Headline",
      "info": "Each new line becomes its own row.",
      "default": "Defy\nLimits"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Activewear, supplements, and training engineered for the women who build their own ceiling."
    },
    {
      "type": "text",
      "id": "primary_label",
      "label": "Primary button",
      "default": "Shop the drop"
    },
    {
      "type": "url",
      "id": "primary_link",
      "label": "Primary button link"
    },
    {
      "type": "text",
      "id": "secondary_label",
      "label": "Secondary button",
      "default": "Watch the film"
    },
    {
      "type": "url",
      "id": "secondary_link",
      "label": "Secondary button link"
    },
    {
      "type": "text",
      "id": "scroll_hint",
      "label": "Scroll hint",
      "default": "Scroll to explore"
    },
    {
      "type": "text",
      "id": "drop_id",
      "label": "Sequence / drop ID (HUD)",
      "default": "DROP-003"
    },
    {
      "type": "text",
      "id": "rail_text",
      "label": "Vertical rail text",
      "default": "Defy Limits / Build Strength / Own Your Story"
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "font_picker",
      "id": "heading_font",
      "label": "Heading font",
      "default": "assistant_n7"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#ffffff"
    },
    {
      "type": "select",
      "id": "heading_style",
      "label": "Heading style",
      "options": [
        { "value": "filled", "label": "Filled" },
        { "value": "outline", "label": "Outline" },
        { "value": "split", "label": "Split (1st filled, 2nd outline)" }
      ],
      "default": "filled"
    },
    {
      "type": "font_picker",
      "id": "body_font",
      "label": "Body font",
      "default": "assistant_n4"
    },
    {
      "type": "color",
      "id": "body_color",
      "label": "Body color",
      "default": "#cdd2da"
    },
    {
      "type": "header",
      "content": "Cursor light"
    },
    {
      "type": "checkbox",
      "id": "enable_cursor_light",
      "label": "Enable cursor light + Tron crosshair",
      "default": true
    },
    {
      "type": "color",
      "id": "cursor_light_outer_color",
      "label": "Outer ring color",
      "default": "#0aeaed"
    },
    {
      "type": "color",
      "id": "cursor_light_inner_color",
      "label": "Inner pip color",
      "default": "#fa0dfd"
    },
    {
      "type": "range",
      "id": "cursor_light_radius",
      "min": 0.4,
      "max": 3,
      "step": 0.1,
      "label": "Radius",
      "default": 1.0
    },
    {
      "type": "range",
      "id": "cursor_light_intensity",
      "min": 0,
      "max": 2,
      "step": 0.05,
      "label": "Intensity",
      "default": 1.0
    },
    {
      "type": "header",
      "content": "Background WebGL"
    },
    {
      "type": "color",
      "id": "color_a",
      "label": "Trail / starfield (start)",
      "default": "#0aeaed"
    },
    {
      "type": "color",
      "id": "color_b",
      "label": "Trail / starfield (end)",
      "default": "#fa0dfd"
    },
    {
      "type": "range",
      "id": "tube_count",
      "min": 0,
      "max": 8,
      "step": 1,
      "label": "Trail tubes",
      "default": 5
    },
    {
      "type": "range",
      "id": "star_count",
      "min": 0,
      "max": 3000,
      "step": 100,
      "label": "Starfield count",
      "default": 1500
    },
    {
      "type": "range",
      "id": "section_height",
      "min": 60,
      "max": 120,
      "step": 5,
      "unit": "vh",
      "label": "Section height",
      "default": 100
    }
  ],
  "blocks": [
    {
      "type": "pillar",
      "name": "Pillar",
      "limit": 3,
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "wear", "label": "Wear (shirt)" },
            { "value": "fuel", "label": "Fuel (bottle)" },
            { "value": "train", "label": "Train (pulse)" },
            { "value": "default", "label": "Default" }
          ],
          "default": "wear"
        },
        { "type": "text", "id": "label", "label": "Label", "default": "Wear" },
        { "type": "text", "id": "sublabel", "label": "Sublabel", "default": "Activewear" }
      ]
    },
    {
      "type": "stat",
      "name": "Stat",
      "limit": 5,
      "settings": [
        { "type": "text", "id": "value", "label": "Value", "default": "12K+" },
        { "type": "text", "id": "label", "label": "Label", "default": "Athletes" }
      ]
    },
    {
      "type": "drop_card",
      "name": "Drop card",
      "limit": 1,
      "settings": [
        { "type": "text", "id": "tag", "label": "Tag", "default": "New drop" },
        { "type": "text", "id": "title", "label": "Title", "default": "Zenith Compression Set" },
        { "type": "text", "id": "meta", "label": "Meta", "default": "4-way stretch · 240gsm" },
        { "type": "text", "id": "cta_label", "label": "CTA label", "default": "View drop" },
        { "type": "url", "id": "link", "label": "Link" }
      ]
    }
  ],
  "presets": [
    {
      "name": "OmniFlex 3D — Neon Cursor Hero",
      "category": "OmniFlex 3D",
      "blocks": [
        { "type": "pillar", "settings": { "icon": "wear", "label": "Wear", "sublabel": "Activewear" } },
        { "type": "pillar", "settings": { "icon": "fuel", "label": "Fuel", "sublabel": "Supplements" } },
        { "type": "pillar", "settings": { "icon": "train", "label": "Train", "sublabel": "Education" } },
        { "type": "stat", "settings": { "value": "12K+", "label": "Athletes" } },
        { "type": "stat", "settings": { "value": "47", "label": "Tested ingredients" } },
        { "type": "stat", "settings": { "value": "100%", "label": "Lab verified" } },
        { "type": "drop_card", "settings": { "tag": "Drop 003", "title": "Zenith Compression Set", "meta": "4-way stretch · 240gsm", "cta_label": "View drop" } }
      ]
    }
  ]
}
{% endschema %}
