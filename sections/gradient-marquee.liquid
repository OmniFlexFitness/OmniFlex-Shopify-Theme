{{ 'section-gradient-marquee.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign marquee_font = section.settings.marquee_font
  assign heading_font = section.settings.heading_font
  assign body_font = section.settings.body_font
  assign quote_font = section.settings.quote_font

  assign row_blocks = section.blocks | where: 'type', 'row'
  assign quote_blocks = section.blocks | where: 'type', 'quote'
  assign quote = quote_blocks | first
  assign signup_blocks = section.blocks | where: 'type', 'signup'
  assign signup = signup_blocks | first
  assign lockup_blocks = section.blocks | where: 'type', 'lockup'
  assign lockup = lockup_blocks | first
-%}

{%- style -%}
  {{ marquee_font | font_face: font_display: 'swap' }}
  {{ heading_font | font_face: font_display: 'swap' }}
  {{ body_font | font_face: font_display: 'swap' }}
  {{ quote_font | font_face: font_display: 'swap' }}

  .gradient-marquee--{{ section.id }} {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px !important;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px !important;
  }
  @media screen and (min-width: 750px) {
    .gradient-marquee--{{ section.id }} {
      padding-top: {{ section.settings.padding_top }}px !important;
      padding-bottom: {{ section.settings.padding_bottom }}px !important;
    }
  }

  #shopify-section-{{ section.id }} .gradient-marquee {
    --marquee-font: {{ marquee_font.family }}, {{ marquee_font.fallback_families }};
    --marquee-color: {{ section.settings.marquee_color }};
    --marquee-stroke: 1.5px;
    --heading-font: {{ heading_font.family }}, {{ heading_font.fallback_families }};
    --heading-color: {{ section.settings.heading_color }};
    --body-font: {{ body_font.family }}, {{ body_font.fallback_families }};
    --body-color: {{ section.settings.body_color }};
    --accent-font: {{ body_font.family }}, {{ body_font.fallback_families }};
    --accent-color: {{ section.settings.body_color }};
    --quote-font: {{ quote_font.family }}, {{ quote_font.fallback_families }};
    --quote-color: {{ section.settings.heading_color }};
  }
{%- endstyle -%}

<gradient-marquee
  class="gradient-marquee gradient-marquee--{{ section.id }}"
  data-base-speed="{{ section.settings.base_speed }}"
  data-scroll-factor="{{ section.settings.scroll_factor }}"
>
  <div class="gradient-marquee__halo gradient-marquee__halo--top" aria-hidden="true"></div>
  <div class="gradient-marquee__halo gradient-marquee__halo--bottom" aria-hidden="true"></div>

  <canvas class="gradient-marquee__particles" aria-hidden="true"></canvas>

  <div class="gradient-marquee__circuit" aria-hidden="true">
    <svg viewBox="0 0 1200 600" preserveAspectRatio="none">
      <defs>
        <linearGradient id="circuit-grad-{{ section.id }}" x1="0" y1="0" x2="1" y2="1">
          <stop offset="0" stop-color="#0aeaed" stop-opacity="0.6"/>
          <stop offset="1" stop-color="#fa0dfd" stop-opacity="0.2"/>
        </linearGradient>
      </defs>
      <path d="M0 100 H 200 L 240 60 H 380 L 420 100 H 600 L 640 60 H 800 L 840 100 H 1000 L 1040 60 H 1200" stroke="url(#circuit-grad-{{ section.id }})" stroke-width="1" fill="none" />
      <path d="M0 480 H 160 L 200 520 H 340 L 380 480 H 540 L 580 520 H 720 L 760 480 H 920 L 960 520 H 1200" stroke="url(#circuit-grad-{{ section.id }})" stroke-width="1" fill="none" />
      <circle cx="240" cy="60" r="3" fill="#0aeaed"/>
      <circle cx="640" cy="60" r="3" fill="#fa0dfd"/>
      <circle cx="380" cy="480" r="3" fill="#0aeaed"/>
      <circle cx="760" cy="480" r="3" fill="#fa0dfd"/>
    </svg>
  </div>

  <div class="gradient-marquee__corners" aria-hidden="true">
    <span></span><span></span><span></span><span></span>
  </div>

  {%- if section.settings.show_hud -%}
    <div class="gradient-marquee__hud" aria-hidden="true">
      <div class="gradient-marquee__hud-left">
        <span>{{ section.settings.hud_left | default: 'Section 04 / Manifesto' | escape }}</span>
        <span class="gradient-marquee__hud-divider"></span>
        <strong class="gradient-marquee__pulse">Live</strong>
        <span class="gradient-marquee__hud-divider"></span>
        <span>SIG <strong class="gradient-marquee__ticker-value">000000</strong></span>
      </div>
      <div>{{ section.settings.hud_right | default: 'OmniFlex // Defy Limits' | escape }}</div>
    </div>
  {%- endif -%}

  {%- if section.settings.manifesto_text != blank -%}
    <div class="gradient-marquee__manifesto">
      {%- if section.settings.manifesto_eyebrow != blank -%}
        <span class="gradient-marquee__manifesto-eyebrow">{{ section.settings.manifesto_eyebrow | escape }}</span>
      {%- endif -%}
      <p class="gradient-marquee__manifesto-text">{{ section.settings.manifesto_text }}</p>
    </div>
  {%- endif -%}

  <div class="gradient-marquee__rows">
    {%- if row_blocks.size > 0 -%}
      {%- for block in row_blocks -%}
        {%- assign style = block.settings.style -%}
        {%- if style == 'gradient' -%}{%- assign style = 'filled' -%}{%- endif -%}
        {%- assign reverse = block.settings.reverse -%}
        {%- assign row_color = block.settings.text_color | default: section.settings.marquee_color -%}
        <div
          class="gradient-marquee__row {% if reverse %}gradient-marquee__row--reverse{% endif %}"
          style="color: {{ row_color }};"
          {{ block.shopify_attributes }}
        >
          <span class="gradient-marquee__item gradient-marquee__item--{{ style }}">
            {{ block.settings.text | escape }}
            <span class="gradient-marquee__dot" aria-hidden="true"></span>
          </span>
        </div>

        {%- unless forloop.last -%}
          <div class="gradient-marquee__divider" aria-hidden="true">
            <span class="gradient-marquee__divider-line"></span>
            <span class="gradient-marquee__divider-tag">
              <span class="gradient-marquee__divider-glyph"></span>
              {{ forloop.index | prepend: '0' | slice: -2, 2 }} / {{ row_blocks.size | prepend: '0' | slice: -2, 2 }}
              <span class="gradient-marquee__divider-sep">//</span>
              {%- case forloop.index -%}
              {%- when 1 -%}WEAR
              {%- when 2 -%}FUEL
              {%- when 3 -%}TRAIN
              {%- else -%}OMNIFLEX
              {%- endcase -%}
            </span>
            <span class="gradient-marquee__divider-line"></span>
          </div>
        {%- endunless -%}
      {%- endfor -%}
    {%- endif -%}
  </div>

  {%- if quote -%}
    <figure class="gradient-marquee__quote" {{ quote.shopify_attributes }}>
      <span class="gradient-marquee__quote-mark" aria-hidden="true">&ldquo;</span>
      <blockquote class="gradient-marquee__quote-text">{{ quote.settings.text }}</blockquote>
      <figcaption class="gradient-marquee__quote-attr">
        <strong>{{ quote.settings.attr_name | escape }}</strong>
        <span class="gradient-marquee__quote-attr-sep" aria-hidden="true"></span>
        <span>{{ quote.settings.attr_role | escape }}</span>
      </figcaption>
    </figure>
  {%- endif -%}

  {%- if signup -%}
    <div class="gradient-marquee__signup" {{ signup.shopify_attributes }}>
      <span class="gradient-marquee__signup-eyebrow">{{ signup.settings.eyebrow | default: 'OmniFlex Comms' | escape }}</span>
      <h3 class="gradient-marquee__signup-title">{{ signup.settings.title | escape }}</h3>
      <p class="gradient-marquee__signup-sub">{{ signup.settings.subtitle | escape }}</p>
      {% form 'customer' %}
        <input type="hidden" name="contact[tags]" value="newsletter">
        <div class="gradient-marquee__form">
          <input
            type="email"
            name="contact[email]"
            placeholder="{{ signup.settings.placeholder | default: 'enter your email' | escape }}"
            required
            aria-label="Email"
          >
          <button type="submit">{{ signup.settings.button | default: 'Subscribe' | escape }}</button>
        </div>
      {% endform %}
      <div class="gradient-marquee__signup-tags">
        {%- if signup.settings.tag_1 != blank -%}<span>{{ signup.settings.tag_1 | escape }}</span>{%- endif -%}
        {%- if signup.settings.tag_2 != blank -%}<span>{{ signup.settings.tag_2 | escape }}</span>{%- endif -%}
        {%- if signup.settings.tag_3 != blank -%}<span>{{ signup.settings.tag_3 | escape }}</span>{%- endif -%}
      </div>
    </div>
  {%- endif -%}

  {%- if lockup -%}
    <div class="gradient-marquee__lockup" aria-hidden="true" {{ lockup.shopify_attributes }}>
      <div class="gradient-marquee__lockup-mark">
        <svg viewBox="0 0 32 32" fill="none">
          <defs>
            <linearGradient id="ofx-lockup-{{ section.id }}" x1="0" y1="0" x2="32" y2="32" gradientUnits="userSpaceOnUse">
              <stop offset="0" stop-color="#0aeaed"/>
              <stop offset="1" stop-color="#fa0dfd"/>
            </linearGradient>
          </defs>
          <path d="M4 16 L16 4 L28 16 L16 28 Z" stroke="url(#ofx-lockup-{{ section.id }})" stroke-width="2" fill="none"/>
          <path d="M10 16 L16 10 L22 16 L16 22 Z" fill="url(#ofx-lockup-{{ section.id }})"/>
        </svg>
        <span>OmniFlex</span>
      </div>
      <span>{{ lockup.settings.tagline | escape }}</span>
      <span>{{ 'now' | date: '%Y' }} OmniFlex Fitness</span>
    </div>
  {%- endif -%}
</gradient-marquee>

<script src="{{ 'gradient-marquee.js' | asset_url }}" defer="defer"></script>

{% schema %}
{
  "name": "OmniFlex 3D — Gradient Marquee",
  "tag": "section",
  "class": "section section--gradient-marquee section--omniflex-3d",
  "settings": [
    {
      "type": "header",
      "content": "HUD bar"
    },
    { "type": "checkbox", "id": "show_hud", "label": "Show HUD bar", "default": true },
    { "type": "text", "id": "hud_left", "label": "HUD left", "default": "Section 04 / Manifesto" },
    { "type": "text", "id": "hud_right", "label": "HUD right", "default": "OmniFlex // Defy Limits" },
    {
      "type": "header",
      "content": "Manifesto"
    },
    { "type": "text", "id": "manifesto_eyebrow", "label": "Eyebrow", "default": "Manifesto · v1.0" },
    {
      "type": "richtext",
      "id": "manifesto_text",
      "label": "Manifesto",
      "default": "<p>OmniFlex bridges <em>science and strength</em> — tools, activewear, and education that empower the modern woman to train with confidence.</p>"
    },
    {
      "type": "header",
      "content": "Marquee behavior"
    },
    {
      "type": "range",
      "id": "base_speed",
      "min": 0,
      "max": 2,
      "step": 0.1,
      "label": "Base speed",
      "default": 0.4
    },
    {
      "type": "range",
      "id": "scroll_factor",
      "min": 0,
      "max": 12,
      "step": 0.5,
      "label": "Scroll velocity factor",
      "default": 6
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "font_picker",
      "id": "marquee_font",
      "label": "Marquee font",
      "default": "assistant_n7"
    },
    {
      "type": "color",
      "id": "marquee_color",
      "label": "Marquee text color",
      "default": "#ffffff"
    },
    {
      "type": "font_picker",
      "id": "heading_font",
      "label": "Heading font (manifesto, signup, lockup)",
      "default": "assistant_n7"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#ffffff"
    },
    {
      "type": "font_picker",
      "id": "body_font",
      "label": "Body / accent font",
      "default": "assistant_n4"
    },
    {
      "type": "color",
      "id": "body_color",
      "label": "Body / accent color",
      "default": "#cdd2da"
    },
    {
      "type": "font_picker",
      "id": "quote_font",
      "label": "Pull-quote font",
      "default": "assistant_n6"
    },
    {
      "type": "header",
      "content": "Section padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 80
    }
  ],
  "blocks": [
    {
      "type": "row",
      "name": "Marquee row",
      "limit": 6,
      "settings": [
        { "type": "text", "id": "text", "label": "Text", "default": "Defy Limits" },
        {
          "type": "select",
          "id": "style",
          "label": "Display style",
          "options": [
            { "value": "filled", "label": "Filled" },
            { "value": "outline", "label": "Outline" }
          ],
          "default": "filled"
        },
        {
          "type": "color",
          "id": "text_color",
          "label": "Row color override",
          "info": "Leave blank to use the section marquee color."
        },
        { "type": "checkbox", "id": "reverse", "label": "Scroll right-to-left", "default": false }
      ]
    },
    {
      "type": "quote",
      "name": "Founder pull-quote",
      "limit": 1,
      "settings": [
        {
          "type": "richtext",
          "id": "text",
          "label": "Quote",
          "default": "<p>I built OmniFlex because the gym is one of the few places where the rules are honest. Show up, do the work, take what's yours.</p>"
        },
        { "type": "text", "id": "attr_name", "label": "Attribution name", "default": "Bertin Kenol" },
        { "type": "text", "id": "attr_role", "label": "Attribution role", "default": "Founder · OmniFlex" }
      ]
    },
    {
      "type": "signup",
      "name": "Newsletter signup",
      "limit": 1,
      "settings": [
        { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "OmniFlex Comms" },
        { "type": "text", "id": "title", "label": "Title", "default": "Get drops, training, and lab notes" },
        { "type": "text", "id": "subtitle", "label": "Subtitle", "default": "Early access to drops, evidence-based training breakdowns, and zero filler. Unsubscribe whenever." },
        { "type": "text", "id": "placeholder", "label": "Email placeholder", "default": "enter your email" },
        { "type": "text", "id": "button", "label": "Button label", "default": "Subscribe" },
        { "type": "text", "id": "tag_1", "label": "Tag 1", "default": "Drops first" },
        { "type": "text", "id": "tag_2", "label": "Tag 2", "default": "No spam" },
        { "type": "text", "id": "tag_3", "label": "Tag 3", "default": "Lab notes weekly" }
      ]
    },
    {
      "type": "lockup",
      "name": "Footer lockup",
      "limit": 1,
      "settings": [
        { "type": "text", "id": "tagline", "label": "Tagline", "default": "Defy Limits · Build Strength · Own Your Story" }
      ]
    }
  ],
  "presets": [
    {
      "name": "OmniFlex 3D — Gradient Marquee",
      "category": "OmniFlex 3D",
      "blocks": [
        { "type": "row", "settings": { "text": "Defy Limits", "style": "filled", "reverse": false } },
        { "type": "row", "settings": { "text": "Build Strength", "style": "outline", "reverse": true } },
        { "type": "row", "settings": { "text": "Own Your Story", "style": "filled", "reverse": false } },
        { "type": "quote" },
        { "type": "signup" },
        { "type": "lockup" }
      ]
    }
  ]
}
{% endschema %}
