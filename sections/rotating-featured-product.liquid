{%- liquid
  assign product = section.settings.product
  assign placeholder = false
  if product == null
    assign placeholder = true
  endif
  assign image_count = 0
  unless placeholder
    assign image_count = product.images.size
  endunless
  assign has_rotation = false
  if image_count > 1
    assign has_rotation = true
  endif
  assign rotation_mode = section.settings.rotation_mode
  assign computed_scroll_height = section.settings.scroll_height
  assign min_scroll = image_count | times: 50
  if computed_scroll_height < min_scroll
    assign computed_scroll_height = min_scroll
  endif
-%}

{{ 'section-rotating-featured-product.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<rotating-featured-product data-section-id="{{ section.id }}">
  <section class="color-{{ section.settings.color_scheme }} {% if section.settings.secondary_background %}background-secondary{% else %}gradient{% endif %}">
    {%- if has_rotation and rotation_mode == 'scroll' -%}
      <div class="rotating-product__scroll-container" style="height: {{ computed_scroll_height }}vh;">
        <div class="rotating-product__sticky">
    {%- endif -%}

          <div class="page-width section-{{ section.id }}-padding">
            <div class="rotating-product grid grid--1-col {% if image_count > 0 or placeholder %}grid--2-col-tablet{% endif %} product--{{ section.settings.media_size }} product--{{ section.settings.media_position }}">
              {%- comment -%} Image area {%- endcomment -%}
              <div class="grid__item product__media-wrapper">
                <div
                  class="rotating-product__frame-container"
                  data-mode="{{ rotation_mode }}"
                  {% if has_rotation %}data-rotatable{% endif %}
                >
                  {%- unless placeholder -%}
                    {%- if product.featured_image -%}
                      <img
                        class="rotating-product__frame"
                        srcset="
                          {%- if product.featured_image.width >= 550 -%}{{ product.featured_image | image_url: width: 550 }} 550w,{%- endif -%}
                          {%- if product.featured_image.width >= 1100 -%}{{ product.featured_image | image_url: width: 1100 }} 1100w,{%- endif -%}
                          {%- if product.featured_image.width >= 1445 -%}{{ product.featured_image | image_url: width: 1445 }} 1445w,{%- endif -%}
                          {%- if product.featured_image.width >= 1680 -%}{{ product.featured_image | image_url: width: 1680 }} 1680w,{%- endif -%}
                          {%- if product.featured_image.width >= 2048 -%}{{ product.featured_image | image_url: width: 2048 }} 2048w,{%- endif -%}
                          {{ product.featured_image | image_url }} {{ product.featured_image.width }}w
                        "
                        src="{{ product.featured_image | image_url: width: 1445 }}"
                        sizes="(min-width: 990px) calc(55vw - 10rem), (min-width: 750px) 50vw, 100vw"
                        alt="{{ product.title | escape }} - image 1 of {{ image_count }}"
                        loading="eager"
                        width="{{ product.featured_image.width }}"
                        height="{{ product.featured_image.height }}"
                        draggable="false"
                      >
                    {%- else -%}
                      <div class="rotating-product__placeholder">
                        {{ 'product-apparel-1' | placeholder_svg_tag: 'placeholder-svg' }}
                      </div>
                    {%- endif -%}
                  {%- else -%}
                    <div class="rotating-product__placeholder">
                      {{ 'product-apparel-1' | placeholder_svg_tag: 'placeholder-svg' }}
                    </div>
                  {%- endunless -%}

                  {%- if has_rotation and rotation_mode == 'drag' -%}
                    <div class="rotating-product__drag-hint">
                      <span class="rotating-product__drag-hint-icon">&larr; &rarr;</span>
                      <span class="rotating-product__drag-hint-text">Drag to rotate</span>
                    </div>
                  {%- endif -%}

                  {%- if has_rotation -%}
                    <div class="rotating-product__frame-counter">
                      <span class="rotating-product__current-frame">1</span> / {{ image_count }}
                    </div>
                  {%- endif -%}
                </div>
              </div>

              {%- comment -%} Product info {%- endcomment -%}
              <div class="grid__item product__info-wrapper">
                <div class="rotating-product__info">
                  {%- unless placeholder -%}
                    <h2 class="rotating-product__title {{ section.settings.heading_size }}">
                      {{ product.title | escape }}
                    </h2>
                    <a href="{{ product.url }}" class="button button--primary rotating-product__view-link">
                      {{ section.settings.button_label | escape }}
                    </a>
                  {%- else -%}
                    <h2 class="rotating-product__title {{ section.settings.heading_size }}">
                      {{ 'onboarding.product_title' | t }}
                    </h2>
                    <a href="#" class="button button--primary rotating-product__view-link" aria-disabled="true">
                      {{ section.settings.button_label | escape }}
                    </a>
                  {%- endunless -%}
                </div>
              </div>
            </div>
          </div>

    {%- if has_rotation and rotation_mode == 'scroll' -%}
        </div>
      </div>
    {%- endif -%}
  </section>

  {%- if has_rotation -%}
    {%- comment -%} Image data for JavaScript {%- endcomment -%}
    <script type="application/json" class="rotating-product__data">
      {
        "imageCount": {{ image_count }},
        "mode": {{ rotation_mode | json }},
        "autoRotate": {{ section.settings.auto_rotate | json }},
        "autoRotateSpeed": {{ section.settings.auto_rotate_speed }},
        "images": [
          {%- for image in product.images -%}
            {%- capture image_srcset -%}
              {%- if image.width >= 550 -%}{{ image | image_url: width: 550 }} 550w, {%- endif -%}
              {%- if image.width >= 1100 -%}{{ image | image_url: width: 1100 }} 1100w, {%- endif -%}
              {%- if image.width >= 1445 -%}{{ image | image_url: width: 1445 }} 1445w, {%- endif -%}
              {%- if image.width >= 1680 -%}{{ image | image_url: width: 1680 }} 1680w, {%- endif -%}
              {%- if image.width >= 2048 -%}{{ image | image_url: width: 2048 }} 2048w, {%- endif -%}
              {{ image | image_url }} {{ image.width }}w
            {%- endcapture -%}
            {
              "src": {{ image | image_url: width: 1445 | json }},
              "srcset": {{ image_srcset | strip | json }},
              "alt": {{ image.alt | default: product.title | escape | json }},
              "width": {{ image.width }},
              "height": {{ image.height }}
            }{% unless forloop.last %},{% endunless %}
          {%- endfor -%}
        ]
      }
    </script>

    {%- comment -%} Preload images for smooth transitions {%- endcomment -%}
    <div class="rotating-product__preload" aria-hidden="true">
      {%- for image in product.images -%}
        {%- unless forloop.first -%}
          <img src="{{ image | image_url: width: 1445 }}" alt="" loading="lazy">
        {%- endunless -%}
      {%- endfor -%}
    </div>

    <script src="{{ 'rotating-featured-product.js' | asset_url }}" defer="defer"></script>
  {%- endif -%}
</rotating-featured-product>

{% schema %}
{
  "name": "Rotating featured product",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "product",
      "id": "product",
      "label": "Product"
    },
    {
      "type": "header",
      "content": "Rotation"
    },
    {
      "type": "select",
      "id": "rotation_mode",
      "options": [
        { "value": "drag", "label": "Drag" },
        { "value": "scroll", "label": "Scroll" }
      ],
      "default": "drag",
      "label": "Rotation mode",
      "info": "Drag: click and drag to rotate. Scroll: product rotates as you scroll down."
    },
    {
      "type": "range",
      "id": "scroll_height",
      "min": 200,
      "max": 600,
      "step": 50,
      "unit": "vh",
      "label": "Scroll area height",
      "info": "Only applies in scroll mode. Higher values = slower rotation.",
      "default": 300
    },
    {
      "type": "checkbox",
      "id": "auto_rotate",
      "default": false,
      "label": "Auto-rotate on load",
      "info": "Slowly cycles through images automatically. Pauses on user interaction."
    },
    {
      "type": "range",
      "id": "auto_rotate_speed",
      "min": 1,
      "max": 10,
      "step": 1,
      "label": "Auto-rotate speed",
      "info": "Frames per second.",
      "default": 3
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "media_size",
      "options": [
        { "value": "small", "label": "Small" },
        { "value": "medium", "label": "Medium" },
        { "value": "large", "label": "Large" }
      ],
      "default": "medium",
      "label": "Image size"
    },
    {
      "type": "select",
      "id": "media_position",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "right", "label": "Right" }
      ],
      "default": "left",
      "label": "Image position"
    },
    {
      "type": "header",
      "content": "Product info"
    },
    {
      "type": "select",
      "id": "heading_size",
      "options": [
        { "value": "h2", "label": "Small" },
        { "value": "h1", "label": "Medium" },
        { "value": "h0", "label": "Large" }
      ],
      "default": "h1",
      "label": "Heading size"
    },
    {
      "type": "text",
      "id": "button_label",
      "default": "View product",
      "label": "Button label"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "checkbox",
      "id": "secondary_background",
      "default": false,
      "label": "Show secondary background"
    },
    {
      "type": "header",
      "content": "Section padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 36
    }
  ],
  "presets": [
    {
      "name": "Rotating featured product"
    }
  ]
}
{% endschema %}
