{{ 'section-floating-3d.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign heading_font = section.settings.heading_font
  assign body_font = section.settings.body_font
  assign pillars = section.blocks | where: 'type', 'pillar'
  assign stats = section.blocks | where: 'type', 'stat'
  assign press_items = section.blocks | where: 'type', 'press'
-%}

{%- style -%}
  {{ heading_font | font_face: font_display: 'swap' }}
  {{ body_font | font_face: font_display: 'swap' }}

  .floating3d--{{ section.id }} {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
    min-height: {{ section.settings.min_section_height }}svh;
  }
  @media screen and (min-width: 750px) {
    .floating3d--{{ section.id }} {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  #shopify-section-{{ section.id }} .floating3d {
    --heading-font: {{ heading_font.family }}, {{ heading_font.fallback_families }};
    --heading-color: {{ section.settings.heading_color }};
    --heading-stroke: 1.5px;
    --body-font: {{ body_font.family }}, {{ body_font.fallback_families }};
    --body-color: {{ section.settings.body_color }};
    --accent-font: {{ body_font.family }}, {{ body_font.fallback_families }};
    --accent-color: {{ section.settings.body_color }};
    --pillar-label-color: {{ section.settings.heading_color }};
    --stat-value-font: {{ heading_font.family }}, {{ heading_font.fallback_families }};
    --stat-value-color: {{ section.settings.heading_color }};
  }
{%- endstyle -%}

<floating-3d
  class="floating3d floating3d--{{ section.id }}"
  data-heading-style="{{ section.settings.heading_style }}"
  data-stat-style="{{ section.settings.heading_style }}"
>
  <canvas class="floating3d__canvas" aria-hidden="true"></canvas>
  <div class="floating3d__noise" aria-hidden="true"></div>

  {%- if section.settings.hud_label != blank -%}
    <div class="floating3d__hud-tag" aria-hidden="true">
      <span>{{ section.settings.hud_label | escape }}</span>
    </div>
  {%- endif -%}

  <div class="floating3d__inner">
    {%- if section.settings.pretitle != blank -%}
      <span class="floating3d__pretitle">{{ section.settings.pretitle | escape }}</span>
    {%- endif -%}
    {%- if section.settings.title != blank -%}
      <h2 class="floating3d__title">{{ section.settings.title }}</h2>
    {%- endif -%}
    {%- if section.settings.body != blank -%}
      <div class="floating3d__body">{{ section.settings.body }}</div>
    {%- endif -%}
    {%- if section.settings.cta_label != blank -%}
      <a class="floating3d__cta" href="{{ section.settings.cta_link | default: '#' }}">
        {{ section.settings.cta_label | escape }}
        <span aria-hidden="true">&rarr;</span>
      </a>
    {%- endif -%}

    {%- if pillars.size > 0 -%}
      <div class="floating3d__pillars">
        {%- for block in pillars -%}
          <a class="floating3d__pillar" href="{{ block.settings.link | default: '#' }}" {{ block.shopify_attributes }}>
            <span class="floating3d__pillar-num">{{ forloop.index | prepend: '0' | slice: -2, 2 }} / {{ pillars.size | prepend: '0' | slice: -2, 2 }}</span>
            <span class="floating3d__pillar-icon" aria-hidden="true">
              {%- case block.settings.icon -%}
              {%- when 'wear' -%}
                <svg viewBox="0 0 40 40" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M8 7l7 2 5-4 5 4 7-2v10l-7 2-5 3-5-3-7-2z"/><path d="M15 17v15M25 17v15"/></svg>
              {%- when 'fuel' -%}
                <svg viewBox="0 0 40 40" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="12" y="5" width="16" height="6" rx="1"/><path d="M14 11h12l-1 22a3 3 0 01-3 3h-4a3 3 0 01-3-3z"/><path d="M15 20h10M15 26h10"/></svg>
              {%- when 'train' -%}
                <svg viewBox="0 0 40 40" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M5 20h3l5-12 7 24 5-15 3 7h7"/></svg>
              {%- when 'lab' -%}
                <svg viewBox="0 0 40 40" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M15 5v10L7 32a3 3 0 003 4h20a3 3 0 003-4l-8-17V5"/><path d="M13 5h14M14 22h12"/></svg>
              {%- when 'recovery' -%}
                <svg viewBox="0 0 40 40" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="20" cy="20" r="14"/><path d="M20 12v8l5 5"/></svg>
              {%- else -%}
                <svg viewBox="0 0 40 40" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M20 4l15 8v16l-15 8-15-8V12z"/></svg>
              {%- endcase -%}
            </span>
            <h3 class="floating3d__pillar-label">{{ block.settings.label | escape }}</h3>
            <p class="floating3d__pillar-desc">{{ block.settings.description | escape }}</p>
            <span class="floating3d__pillar-link">
              {{ block.settings.cta_label | default: 'Explore' | escape }} <span aria-hidden="true">&rarr;</span>
            </span>
          </a>
        {%- endfor -%}
      </div>
    {%- endif -%}

    {%- if stats.size > 0 -%}
      <div class="floating3d__stats">
        {%- for block in stats -%}
          <div class="floating3d__stat" {{ block.shopify_attributes }}>
            <span class="floating3d__stat-value">{{ block.settings.value | escape }}</span>
            <span class="floating3d__stat-label">{{ block.settings.label | escape }}</span>
          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}

    {%- if press_items.size > 0 -%}
      <div class="floating3d__press">
        {%- if section.settings.press_label != blank -%}
          <span class="floating3d__press-label">{{ section.settings.press_label | escape }}</span>
        {%- endif -%}
        <div class="floating3d__press-row">
          {%- for block in press_items -%}
            <span class="floating3d__press-item {% if block.settings.bold %}floating3d__press-item--bold{% endif %}" {{ block.shopify_attributes }}>{{ block.settings.text | escape }}</span>
          {%- endfor -%}
        </div>
      </div>
    {%- endif -%}
  </div>

  <script type="application/json" class="floating3d__data">
    {
      "colorA": {{ section.settings.color_a | json }},
      "colorB": {{ section.settings.color_b | json }},
      "shapeCount": {{ section.settings.shape_count }},
      "parallaxStrength": {{ section.settings.parallax_strength }}
    }
  </script>

  <script type="importmap">
    {
      "imports": {
        "three": "https://cdn.jsdelivr.net/npm/three@0.162.0/build/three.module.js",
        "three/addons/": "https://cdn.jsdelivr.net/npm/three@0.162.0/examples/jsm/"
      }
    }
  </script>
  <script type="module" src="{{ 'floating-3d.js' | asset_url }}"></script>
</floating-3d>

{% schema %}
{
  "name": "OmniFlex 3D — Floating Objects",
  "tag": "section",
  "class": "section section--floating3d section--omniflex-3d",
  "settings": [
    {
      "type": "header",
      "content": "Heading"
    },
    {
      "type": "text",
      "id": "hud_label",
      "label": "HUD label",
      "default": "SECTION 03 // OmniFlex System"
    },
    {
      "type": "text",
      "id": "pretitle",
      "label": "Pretitle",
      "default": "Built without limits"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Train heavier. Recover smarter. <em>Own the rep.</em>"
    },
    {
      "type": "richtext",
      "id": "body",
      "label": "Body",
      "default": "<p>The OmniFlex system pairs lab-tested supplements with biomechanically-tuned activewear and on-demand training.</p>"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "CTA label",
      "default": "Enter the system"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "CTA link"
    },
    {
      "type": "text",
      "id": "press_label",
      "label": "Press strip label",
      "default": "As featured in"
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "font_picker",
      "id": "heading_font",
      "label": "Heading font",
      "default": "assistant_n7"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#ffffff"
    },
    {
      "type": "select",
      "id": "heading_style",
      "label": "Heading style",
      "options": [
        { "value": "filled", "label": "Filled" },
        { "value": "outline", "label": "Outline" }
      ],
      "default": "filled"
    },
    {
      "type": "font_picker",
      "id": "body_font",
      "label": "Body font",
      "default": "assistant_n4"
    },
    {
      "type": "color",
      "id": "body_color",
      "label": "Body color",
      "default": "#cdd2da"
    },
    {
      "type": "header",
      "content": "Background WebGL"
    },
    {
      "type": "color",
      "id": "color_a",
      "label": "Lighting (start)",
      "default": "#0aeaed"
    },
    {
      "type": "color",
      "id": "color_b",
      "label": "Lighting (end)",
      "default": "#fa0dfd"
    },
    {
      "type": "range",
      "id": "shape_count",
      "min": 4,
      "max": 30,
      "step": 1,
      "label": "Floating shape count",
      "default": 14
    },
    {
      "type": "range",
      "id": "parallax_strength",
      "min": 0,
      "max": 4,
      "step": 0.1,
      "label": "Parallax strength",
      "default": 1.5
    },
    {
      "type": "header",
      "content": "Section sizing"
    },
    {
      "type": "range",
      "id": "min_section_height",
      "min": 40,
      "max": 120,
      "step": 5,
      "unit": "vh",
      "label": "Minimum height",
      "default": 70
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 40
    }
  ],
  "blocks": [
    {
      "type": "pillar",
      "name": "Pillar",
      "limit": 3,
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "wear", "label": "Wear" },
            { "value": "fuel", "label": "Fuel" },
            { "value": "train", "label": "Train" },
            { "value": "lab", "label": "Lab" },
            { "value": "recovery", "label": "Recovery" }
          ],
          "default": "wear"
        },
        { "type": "text", "id": "label", "label": "Label", "default": "Wear" },
        { "type": "text", "id": "description", "label": "Description", "default": "Compression apparel engineered for full-range mobility." },
        { "type": "text", "id": "cta_label", "label": "CTA label", "default": "Shop apparel" },
        { "type": "url", "id": "link", "label": "Link" }
      ]
    },
    {
      "type": "stat",
      "name": "Stat",
      "limit": 6,
      "settings": [
        { "type": "text", "id": "value", "label": "Value", "default": "12K+" },
        { "type": "text", "id": "label", "label": "Label", "default": "Athletes" }
      ]
    },
    {
      "type": "press",
      "name": "Press logo",
      "limit": 8,
      "settings": [
        { "type": "text", "id": "text", "label": "Logo text", "default": "Vogue" },
        { "type": "checkbox", "id": "bold", "label": "Bold sans-serif (vs italic serif)", "default": false }
      ]
    }
  ],
  "presets": [
    {
      "name": "OmniFlex 3D — Floating Objects",
      "category": "OmniFlex 3D",
      "blocks": [
        { "type": "pillar", "settings": { "icon": "wear", "label": "Wear", "description": "Compression apparel engineered for full-range mobility, sweat-grip, and a silhouette built to be lived in.", "cta_label": "Shop apparel" } },
        { "type": "pillar", "settings": { "icon": "fuel", "label": "Fuel", "description": "Lab-tested supplements calibrated for women in training: clean macros, transparent dosing, third-party verified.", "cta_label": "Shop fuel" } },
        { "type": "pillar", "settings": { "icon": "train", "label": "Train", "description": "Biomechanically-coded programs and education, written by coaches who actually train women, not interns.", "cta_label": "Start training" } },
        { "type": "stat", "settings": { "value": "12K+", "label": "Athletes onboarded" } },
        { "type": "stat", "settings": { "value": "47", "label": "Tested ingredients" } },
        { "type": "stat", "settings": { "value": "96%", "label": "Recovery rate" } },
        { "type": "stat", "settings": { "value": "2024", "label": "Founded" } },
        { "type": "press", "settings": { "text": "Vogue", "bold": false } },
        { "type": "press", "settings": { "text": "WOMEN'S HEALTH", "bold": true } },
        { "type": "press", "settings": { "text": "Forbes", "bold": false } },
        { "type": "press", "settings": { "text": "POPSUGAR", "bold": true } },
        { "type": "press", "settings": { "text": "Hypebeast", "bold": false } }
      ]
    }
  ]
}
{% endschema %}
