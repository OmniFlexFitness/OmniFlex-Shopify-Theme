        {
          "type": "select",
          "id": "decode_replay",
          "label": "Replay decode on hover",
          "options": [
            { "value": "", "label": "Inherit" },
            { "value": "once", "label": "Once per page load" },
            { "value": "always", "label": "Every hover" }
          ],
          "default": ""
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Neon button group",
      "blocks": [
        {
          "type": "neon_button",
          "settings": {
            "button_label": "Shop now",
            "color": "cyan",
            "style": "outline",
            "glitch": true,
            "decode": true
          }
        },
        {
          "type": "neon_button",
          "settings": {
            "button_label": "Learn more",
            "color": "purple",
            "style": "fill",
            "glitch": true
          }
        }
      ]
    }
  ]
}
{% endschema %}
